# =========================
# Core App Configuration
# =========================
# Comma-separated list. Use * only for local dev.
ALLOW_ORIGINS=*

# Shared DB URL (optional).
# If empty, backend falls back to local SQLite at database/portfolio.db
DATABASE_URL=

# ADK session DB URI (optional).
# If empty, backend falls back to DATABASE_URL, then local SQLite.
SESSION_SERVICE_URI=

# =========================
# Google Cloud / GenAI
# =========================
# Recommended for Vertex AI usage (including embeddings in pgvector mode).
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Optional if using Gemini API key flow (non-Vertex client init path).
GOOGLE_API_KEY=

# =========================
# Telemetry / Logging
# =========================
# Optional GCS bucket name (without gs:// prefix in this project config).
LOGS_BUCKET_NAME=

# Set to NO_CONTENT to enable metadata-only telemetry upload.
# Keep false to disable prompt/response capture pipeline.
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=NO_CONTENT

# Optional telemetry settings (used when bucket + capture are enabled).
OTEL_INSTRUMENTATION_GENAI_UPLOAD_FORMAT=jsonl
OTEL_INSTRUMENTATION_GENAI_COMPLETION_HOOK=upload
OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai_latest_experimental
GENAI_TELEMETRY_PATH=completions
COMMIT_SHA=dev
OTEL_RESOURCE_ATTRIBUTES=service.namespace=backend,service.version=dev

# =========================
# RAG Backend Selection
# =========================
# local | pgvector | vertex
RAG_BACKEND=local

# Embedding model used for vector indexing/query embeddings.
RAG_EMBEDDING_MODEL=text-embedding-004

# =========================
# pgvector Settings
# =========================
# Required when RAG_BACKEND=pgvector
PGVECTOR_DSN=
PGVECTOR_TABLE=knowledge_chunks
PGVECTOR_EMBEDDING_DIM=768

# true => sync knowledge chunks into vector table during app startup.
# Query-time retrieval remains read-only.
RAG_AUTO_INGEST=true
